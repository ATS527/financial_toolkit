services:
  postgres:
    image: postgres:16
    container_name: financial-toolkit-postgres
    restart: always
    environment:
      POSTGRES_DB: financial_toolkit
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data

volumes:
  postgres-data: